# Supabase – veřejné klíče (bezpečné na klientovi)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic – pouze server-side, NIKDY ne NEXT_PUBLIC_!
ANTHROPIC_API_KEY=sk-ant-...

# MapTiler – veřejný klíč pro mapové dlaždice (MapLibre GL)
# Získej na: https://cloud.maptiler.com/ → Projects → API key
# Bez tohoto klíče se mapa přepne na Overpass API (OpenStreetMap dlaždice)
NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-api-key
